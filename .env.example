# Required for fetching Portfolio Projects from Notion
NOTION_API_KEY="secret_your_notion_integration_token"
NOTION_DATABASE_ID="your_database_id_here"

# Hero-video publishing configuration used by the Justfile
# Configure the "r2" remote and its credentials separately with `rclone config`.
HERO_R2_REMOTE="r2:your-bucket/hero"
HERO_R2_PUBLIC_BASE_URL="https://media.example.com/hero"

# Required only when running hero-sync with --purge
CLOUDFLARE_ZONE_ID="your_cloudflare_zone_id"
CLOUDFLARE_API_TOKEN="your_cache_purge_api_token"
